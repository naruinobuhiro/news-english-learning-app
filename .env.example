# 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を入力してください

# Gemini API Key (Google AI Studio から取得)
GEMINI_API_KEY=your_gemini_api_key_here

# Vercel KV (Redis) - Vercel ダッシュボードから取得
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here

# Google Sheets API
# GCP サービスアカウントのメールアドレス
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
# GCP サービスアカウントの秘密鍵（改行を \n に置換）
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----
# 単語帳を管理するスプレッドシートのID（URLから取得）
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Cron認証シークレット（任意の長いランダム文字列）
CRON_SECRET=your_cron_secret_here
